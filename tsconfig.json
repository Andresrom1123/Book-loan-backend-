{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": true,
    "strictNullChecks": true,
    "outDir": "dist",
    "types": ["mocha", "node"]
  },
  "exclude": ["node_modules", "dist"],
  "lib": ["es2022"]
}
